# Copy to .env (already gitignored) and fill values. Never commit real values.

# --- AI provider selection ---
# Which LLM to use: "gemini" (free default, gemini-2.5-flash) or "claude" (Anthropic Haiku 4.5).
LLM_PROVIDER=gemini
# Optional override of the provider's default model (e.g. gemini-2.5-flash-lite, claude-sonnet-4-6).
LLM_MODEL=

# --- API keys (only the one for the selected provider is required) ---
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Delivery ---
# DRY_RUN=1 (default): render to stdout only, no external send.
# DRY_RUN=0 + DELIVERY=slack|email: actually send.
DRY_RUN=1
DELIVERY=

# Slack (used when DELIVERY=slack)
SLACK_WEBHOOK_URL=

# Email (used when DELIVERY=email)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
MAIL_TO=

# --- Collection ---
WINDOW_HOURS=26
ARXIV_PER_CATEGORY_LIMIT=30
