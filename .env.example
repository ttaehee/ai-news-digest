# Copy to .env (already gitignored) and fill values. Never commit real values.

# --- Required for AI processing ---
ANTHROPIC_API_KEY=

# --- Delivery ---
# DRY_RUN=1 (default): render to stdout only, no external send.
# DRY_RUN=0 + DELIVERY=slack|email: actually send.
DRY_RUN=1
DELIVERY=

# Slack (used when DELIVERY=slack)
SLACK_WEBHOOK_URL=

# Email (used when DELIVERY=email)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
MAIL_TO=

# --- Collection ---
WINDOW_HOURS=26
ARXIV_PER_CATEGORY_LIMIT=30
